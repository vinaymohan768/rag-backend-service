OPENAI_API_KEY=sk-...

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ragdb
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag

EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
LLM_MODEL=gpt-4o-mini

# Chunking defaults (overridable per request)
DEFAULT_CHUNK_STRATEGY=sentence   # fixed | sentence | paragraph
DEFAULT_CHUNK_SIZE=512
DEFAULT_CHUNK_OVERLAP=64

# Retrieval defaults
DEFAULT_TOP_K=8
DEFAULT_RERANK_TOP_K=3
HYBRID_ALPHA=0.7    # weight for vector score vs BM25 (1.0 = pure vector)
